// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  icon      String? // emoji yoki icon nomi
  imageUrl  String? // "Nima uchun komplektlaymiz" bloki uchun katta rasm
  sortOrder Int       @default(0)
  products  Product[]
}

model Product {
  id            String      @id @default(cuid())
  slug          String      @unique
  name          String
  description   String
  price         Int // narxi, so'mda
  oldPrice      Int? // chegirmagacha bo'lgan narx (agar bo'lsa)
  imageUrl      String?
  stock         Int         @default(0)
  isActive      Boolean     @default(true)
  isFeatured    Boolean     @default(false)
  rating        Float       @default(0)
  reviewCount   Int         @default(0)
  soldCount     Int         @default(0)
  category      Category    @relation(fields: [categoryId], references: [id])
  categoryId    String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  rfqItems      RfqItem[]
}

model User {
  id          String       @id @default(cuid())
  phone       String       @unique
  companyName String?
  contactName String?
  createdAt   DateTime     @default(now())
  requests    RfqRequest[]
  sessions    Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model RfqRequest {
  id            String     @id @default(cuid())
  companyName   String
  contactName   String
  phone         String
  requestType   String // masalan: "Ob'ekt komplektatsiyasi", "Aniq mahsulot"
  comment       String?
  status        RfqStatus  @default(NEW)
  items         RfqItem[]
  user          User?      @relation(fields: [userId], references: [id])
  userId        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model RfqItem {
  id           String     @id @default(cuid())
  request      RfqRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId    String
  product      Product    @relation(fields: [productId], references: [id])
  productId    String
  quantity     Int
  priceAtQuote Int // so'rov vaqtidagi narx
}

enum RfqStatus {
  NEW
  IN_REVIEW
  QUOTED
  CONFIRMED
  CANCELLED
}
